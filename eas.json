{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "channel": "production",
      "android": {
        "buildType": "store"
      }
    },
    "preview": {
      "channel": "staging",
      "android": {
        "buildType": "apk"
      }
    },
    "development": {
      "channel": "development",
      "developmentClient": true,
      "distribution": "internal"
    }
  }
}
